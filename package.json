{
  "name": "newjeans-pets",
  "version": "1.0.1",
  "private": true,
  "description": "Electron desktop pet shell wired to five finalized NewJeans pet atlases.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "dist:win": "electron-builder --win --x64 --publish never",
    "dist:mac": "electron-builder --mac dmg zip"
  },
  "devDependencies": {
    "electron": "22.3.27",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.newjeans.desktoppets",
    "productName": "NewJeans Pets",
    "directories": {
      "output": "dist"
    },
    "files": [
      "app.js",
      "build/icon.ico",
      "build/icon.icns",
      "index.html",
      "main.js",
      "package.json",
      "pet-data.js",
      "preload.js",
      "styles.css",
      "minji/hatch-runs/final/spritesheet.webp",
      "hanni/hatch-runs/final/spritesheet.webp",
      "daniel/hatch-runs/final/spritesheet.webp",
      "haerin/hatch-runs/final/spritesheet.webp",
      "hyein/hatch-runs/final/spritesheet.webp"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "build/icon.icns",
        "to": "icon.icns"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.entertainment"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "NewJeans-Pets-win7-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "NewJeans-Pets-win7-${version}.${ext}"
    }
  }
}
